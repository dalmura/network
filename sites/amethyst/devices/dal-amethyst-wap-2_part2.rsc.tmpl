#
# dal-amethyst-wap-2
#

#
# Certificates
#

/certificate
add name=ca days-valid=10950 common-name=wap-2.amethyst.dalmura.cloud key-usage=key-cert-sign,crl-sign
add name=server days-valid=10950 common-name=wap-2.amethyst.dalmura.cloud subject-alt-name=DNS:wap-2.amethyst.dalmura.cloud organization=dalmura unit=amethyst

sign ca name=root-ca
:delay 2
sign ca=root-ca server name=server
:delay 2

set root-ca trusted=yes
set server trusted=yes

/ip/service/set www-ssl port=8443 tls-version=only-1.2 address=192.168.71.192/26 certificate=server disabled=no
/ip/service/set api-ssl tls-version=only-1.2 address=192.168.71.192/26 certificate=server disabled=no

/ip/service/set api disabled=yes
/ip/service/set www disabled=yes
